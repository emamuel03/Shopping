@model Shopping.Models.StateViewModel

@{
    ViewData["Title"] = "AddState";
}

<h1>Crear</h1>

<h4>Estados</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="AddState">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="CountryId"/>
            <partial name="_State" />
            <div class="form-group mt-4">
                <input type="submit" value="Crear" class="btn btn-outline-primary" />
                <a asp-action="Index" asp-route-id="@Model.CountryId" class="btn btn-outline-success">Volver</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}